# ============================================================
# Development Dockerfile
# Hot reload + dev tools + debug mode
# NOT for production — image is larger and less secure
# ============================================================
FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONPATH=/app \
    ENV=development \
    DEBUG=true

WORKDIR /app

# Install dev dependencies (includes test tools, linters)
COPY requirements.dev.txt .
RUN pip install --no-cache-dir -r requirements.dev.txt

# Don't copy code — mount it as volume instead
# Changes to code reflect instantly without rebuild
# COPY app/ ./app/  ← NOT doing this becuase if there are any code changes we need to copy the code tp app folder again and need to rebuild the docker 

EXPOSE 8000

# Run with --reload — restarts on code changes
CMD ["uvicorn":"app.main:app", \
    "--host","0.0.0.0", \
    "--port","8000", \
    "--reload", \
    "--reload-dir","/app"
    ]

